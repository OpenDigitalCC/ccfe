#!/bin/sh
#
# ccfe-build -- backend for CCFE's guided builders (ROADMAP M5).
#
# Creates and extends menus, forms and config in the user's XDG directories
# and validates objects with `ccfe -k`.  It is invoked by the builder forms
# (see builder.menu / builder.d/) via run: actions, which pass the form field
# values as $CCFE_FIELD_* environment variables -- so user input never goes
# through shell interpolation (it arrives as ordinary arguments here).
#
# Usage:
#   ccfe-build new-menu   NAME TITLE
#   ccfe-build add-item   MENU ID DESCR ACTION
#   ccfe-build edit-item  MENU ID DESCR    # change an existing item's description
#   ccfe-build new-form   NAME TITLE
#   ccfe-build add-field  FORM ID LABEL [TYPE]
#   ccfe-build set-action FORM ACTION
#   ccfe-build set-config KEY VALUE        # global { } setting in the user conf
#   ccfe-build set-var    NAME VALUE       # variables { } entry in the user conf
#   ccfe-build show-config                 # global { } print the user conf
#   ccfe-build list                        # list the user's objects
#   ccfe-build chown      NAME USER[:GROUP] # change ownership of one of my objects
#   ccfe-build list-objects                # object names (for a list_cmd)
#   ccfe-build list-users / list-groups    # local users / groups (for a list_cmd)
#
#  Copyright (C) 2026 CCFE contributors.  GPL-2.0-or-later.

set -eu

realname=ccfe
objdir="${XDG_DATA_HOME:-$HOME/.local/share}/$realname/$realname"
cfgdir="${XDG_CONFIG_HOME:-$HOME/.config}/$realname"
conf="$cfgdir/$realname.conf"

# The CCFE binary (set by ccfe for its children; else found on PATH).
ccfe="${CCFE_BIN_DIR:-}/ccfe"
[ -x "$ccfe" ] || ccfe=ccfe

die() { echo "ccfe-build: $*" >&2; exit 1; }

valid_name() {
  case "$1" in
    '' | *[!A-Za-z0-9_.-]* | .* ) return 1 ;;
    * ) return 0 ;;
  esac
}

validate() { "$ccfe" -k "$1"; }

ensure_dirs() { mkdir -p "$objdir" "$cfgdir"; }

# set_in_block BLOCK KEY VALUE -- set "KEY = VALUE" inside the named `BLOCK { }`
# section of the user conf, creating the conf and/or the block if needed.  An
# existing KEY in that block is replaced; otherwise the line is inserted before
# the block's closing brace.  Block-aware so global{} and variables{} coexist.
set_in_block() {
  block=$1; key=$2; val=$3
  ensure_dirs
  [ -f "$conf" ] || : > "$conf"
  if ! grep -qE "^[[:space:]]*${block}[[:space:]]*\{" "$conf"; then
    printf '%s {\n}\n' "$block" >> "$conf"
  fi
  tmp="$conf.tmp.$$"
  awk -v block="$block" -v key="$key" -v val="$val" '
    $0 ~ ("^[[:space:]]*" block "[[:space:]]*\\{") { inblk=1 }
    inblk && !done && $0 ~ ("^[[:space:]]*" key "[[:space:]]*=") {
      print "  " key " = " val; done=1; next
    }
    inblk && /^[[:space:]]*}/ {
      if (!done) print "  " key " = " val
      inblk=0; done=1; print; next
    }
    { print }
  ' "$conf" > "$tmp"
  mv "$tmp" "$conf"
  chmod 0644 "$conf"
}

cmd=${1:-}
[ -n "$cmd" ] || die "no command (try: new-menu, add-item, new-form, add-field, set-action, set-config, list)"
shift

case "$cmd" in
  new-menu)
    name=${1:-}; title=${2:-}
    valid_name "$name" || die "invalid menu name \"$name\" (use letters, digits, _ . -)"
    ensure_dirs
    f="$objdir/$name.menu"
    [ -e "$f" ] && die "menu already exists: $f"
    { printf 'title {\n  %s\n}\n' "$title"; } > "$f"
    chmod 0644 "$f"
    echo "Created menu: $f"
    echo "Now add items with the \"Add a menu item\" form."
    ;;

  add-item)
    name=${1:-}; id=${2:-}; descr=${3:-}; action=${4:-}
    if [ -z "$id" ] || [ -z "$action" ]; then
      die "add-item needs MENU ID DESCR ACTION"
    fi
    f="$objdir/$name.menu"
    [ -f "$f" ] || die "no such menu: $f (create it first)"
    { printf 'item {\n  id     = %s\n  descr  = %s\n  action = %s\n}\n' \
        "$id" "$descr" "$action"; } >> "$f"
    echo "Added item \"$id\" to menu \"$name\""
    validate "$name"
    ;;

  edit-item)
    name=${1:-}; id=${2:-}; descr=${3:-}
    if [ -z "$id" ] || [ -z "$descr" ]; then
      die "edit-item needs MENU ID DESCR"
    fi
    f="$objdir/$name.menu"
    [ -f "$f" ] || die "no such menu: $f"
    tmp="$f.tmp.$$"
    # Replace the descr line of the item block whose id matches; awk exits 1
    # (no output kept) if the id is not found.
    if awk -v target="$id" -v newdescr="$descr" '
        /^[[:space:]]*item[[:space:]]*\{/ { inblock=1; curid="" }
        inblock && /^[[:space:]]*id[[:space:]]*=/ {
          v=$0; sub(/^[[:space:]]*id[[:space:]]*=[[:space:]]*/,"",v)
          sub(/[[:space:]]+$/,"",v); curid=v
        }
        inblock && curid==target && /^[[:space:]]*descr[[:space:]]*=/ {
          print "  descr  = " newdescr; matched=1; inblock=0; next
        }
        /^[[:space:]]*\}/ { inblock=0 }
        { print }
        END { exit (matched ? 0 : 1) }
      ' "$f" > "$tmp"
    then
      mv "$tmp" "$f"
      chmod 0644 "$f"
      echo "Updated description of item \"$id\" in menu \"$name\""
      validate "$name"
    else
      rm -f "$tmp"
      die "item id \"$id\" not found in menu \"$name\""
    fi
    ;;

  new-form)
    name=${1:-}; title=${2:-}
    valid_name "$name" || die "invalid form name \"$name\""
    ensure_dirs
    f="$objdir/$name.form"
    [ -e "$f" ] && die "form already exists: $f"
    { printf 'title {\n  %s\n}\n' "$title"; } > "$f"
    chmod 0644 "$f"
    echo "Created form: $f  (add fields, then set-action)"
    ;;

  add-field)
    name=${1:-}; id=${2:-}; label=${3:-}; type=${4:-STRING}
    [ -n "$id" ] || die "add-field needs FORM ID LABEL [TYPE]"
    f="$objdir/$name.form"
    [ -f "$f" ] || die "no such form: $f"
    { printf 'field {\n  id    = %s\n  len   = 20\n  type  = %s\n  label = %s\n}\n' \
        "$id" "$type" "$label"; } >> "$f"
    echo "Added field \"$id\" ($type) to form \"$name\""
    ;;

  set-action)
    name=${1:-}; action=${2:-}
    [ -n "$action" ] || die "set-action needs FORM ACTION"
    f="$objdir/$name.form"
    [ -f "$f" ] || die "no such form: $f"
    { printf 'action { %s }\n' "$action"; } >> "$f"
    echo "Set action on form \"$name\""
    validate "$name"
    ;;

  set-config)
    key=${1:-}; val=${2:-}
    [ -n "$key" ] || die "set-config needs KEY VALUE"
    set_in_block global "$key" "$val"
    echo "Set $key = $val in the global { } block of $conf"
    ;;

  set-var)
    name=${1:-}; val=${2:-}
    [ -n "$name" ] || die "set-var needs NAME VALUE"
    case "$name" in
      *[!A-Za-z0-9_]* | '' ) die "invalid variable name \"$name\" (letters, digits, _)" ;;
    esac
    set_in_block variables "$name" "$val"
    echo "Set variable $name in the variables { } block of $conf"
    ;;

  show-config)
    if [ -f "$conf" ]; then
      echo "# $conf"
      cat "$conf"
    else
      echo "No personal config yet ($conf)."
      echo "Use the \"Configure CCFE\" wizard or set-config to create one."
    fi
    ;;

  list)
    echo "Objects in $objdir:"
    ls -1 "$objdir" 2>/dev/null || echo "  (none yet)"
    echo "Config: $conf"
    ;;

  list-menus)   # one menu name per line (for a form's list_cmd)
    for f in "$objdir"/*.menu; do
      [ -e "$f" ] || continue
      b=${f##*/}; echo "${b%.menu}"
    done
    ;;

  list-items)   # one item id per line for MENU (for a form's list_cmd)
    name=${1:-}
    f="$objdir/$name.menu"
    [ -f "$f" ] || exit 0
    awk '/^[[:space:]]*id[[:space:]]*=/ {
      v=$0; sub(/^[[:space:]]*id[[:space:]]*=[[:space:]]*/,"",v)
      sub(/[[:space:]]+$/,"",v); print v }' "$f"
    ;;

  list-forms)
    for f in "$objdir"/*.form; do
      [ -e "$f" ] || continue
      b=${f##*/}; echo "${b%.form}"
    done
    ;;

  list-objects)   # every menu/form name, deduped (for a form's list_cmd)
    for f in "$objdir"/*.menu "$objdir"/*.form; do
      [ -e "$f" ] || continue
      b=${f##*/}; echo "${b%.*}"
    done | sort -u
    ;;

  list-users)     # local login names, for the ownership picker
    if command -v getent >/dev/null 2>&1; then
      getent passwd | cut -d: -f1
    else
      cut -d: -f1 /etc/passwd
    fi | sort -u
    ;;

  list-groups)    # local group names, for the ownership picker
    if command -v getent >/dev/null 2>&1; then
      getent group | cut -d: -f1
    else
      cut -d: -f1 /etc/group
    fi | sort -u
    ;;

  chown)          # change ownership of one of MY objects (FEATURE-REQUESTS C1)
    name=${1:-}; owner=${2:-}
    valid_name "$name" || die "invalid object name \"$name\""
    # USER, USER:GROUP or :GROUP, restricted characters (no shell metachars,
    # no path separators) so the value cannot escape into the chown arguments.
    case "$owner" in
      '' | *[!A-Za-z0-9_.:-]* ) die "invalid owner \"$owner\" (USER[:GROUP])" ;;
    esac
    # Only ever touch objects under MY objdir; valid_name already forbids '/'
    # and a leading dot, so $name cannot traverse out of it -- a system-owned
    # object (which restricted mode locks) is never reachable here.
    found=0
    for suffix in .menu .form .d; do
      t="$objdir/$name$suffix"
      [ -e "$t" ] || continue
      found=1
      chown -R -- "$owner" "$t" \
        || die "could not change owner of $t to $owner (need more privilege?)"
      echo "Changed owner of $t to $owner"
    done
    [ "$found" = 1 ] || die "no object named \"$name\" under $objdir"
    ;;

  *)
    die "unknown command: $cmd"
    ;;
esac
