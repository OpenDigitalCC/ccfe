# Debian package build artifacts
debian/ccfe/
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/*.substvars
debian/*.debhelper.log

# Built packages (produced in the parent directory by dpkg-buildpackage)
/*.deb
/*.buildinfo
/*.changes

# RPM build tree (transient; `make rpm` cleans it, dist/ keeps the .rpm)
/rpmbuild/

# Local-only working notes (feeds the ROADMAP)
FEATURE-REQUESTS.md

# Local scratch (commit messages, one-off diagnostics)
tmp/
