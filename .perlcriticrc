# Perl::Critic configuration for CCFE.
#
# Policy: new code under src/lib/CCFE/ is held to severity 3 ("harsh"),
# aiming for 2 over time.  The legacy single file src/ccfe.pl is NOT linted
# here yet -- it predates use strict and would bury the signal; it is brought
# under the gate incrementally as it is de-globalised (see REFACTOR.md sec 3-4).
# CI therefore runs:  perlcritic src/lib
#
# Run with the default severity from this file:
#   perlcritic src/lib
# Or stricter, to see what tightening to 2 would flag:
#   perlcritic --severity 2 src/lib

severity = 3

# `use v5.36` is the idiomatic modern way to turn on the feature bundle
# (strict, warnings, signatures); it is not a version-string smell.
[-ValuesAndExpressions::ProhibitVersionStrings]

# We do not mandate the /x flag on every regular expression; it adds noise to
# trivial patterns.  Complex patterns should still use it by good judgement.
[-RegularExpressions::RequireExtendedFormatting]

# Lookup helpers (e.g. CCFE::Theme::color_number/pair_number) return undef in
# scalar context to mean "not found"; that is a deliberate, documented API and
# callers use scalar context.  `return;` would yield an empty list in list
# context and misbehave, so an explicit `return undef` is correct here.
[-Subroutines::ProhibitExplicitReturnUndef]

# Our modules use `use v5.36` subroutine SIGNATURES, e.g. `sub color_number
# ($name)` and `sub pair_for ($fg, $bg = undef)` -- not C-style prototypes.
# The signatures are load-bearing (the bodies use the named params directly)
# and are the deliberate modern idiom here (see the ProhibitVersionStrings note
# above).  Older Perl::Critic / PPI -- as shipped in the CI image -- predates
# signature awareness and reports every signature as a prototype, so exempt the
# policy rather than abandon signatures.  (We do not use real prototypes
# anywhere; a newer Perl::Critic already passes these files clean.)
[-Subroutines::ProhibitSubroutinePrototypes]
